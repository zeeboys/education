generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  walletAddress     String?   @unique
  email             String?   @unique
  username          String?   @unique
  displayName       String?
  bio               String?
  avatar            String?
  reputation        Int       @default(0)
  totalEarned       String    @default("0")
  skills            String[]
  certifications   Certification[]
  createdBounties   Bounty[]  @relation("BountyCreator")
  assignedBounties  Bounty[]  @relation("BountyAssignee")
  submissions       Submission[]
  reviews           Review[]
  courses           Course[]  @relation("CourseCreator")
  certificates      Certificate[] @relation("Certificates")
  assessmentAttempts AssessmentAttempt[] @relation("AssessmentAttempts")
  enrollments       Enrollment[] @relation("Enrollments")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("users")
}

model Bounty {
  id          String      @id @default(cuid())
  title       String
  description String
  category    BountyCategory
  difficulty  Difficulty
  reward      String
  status      BountyStatus @default(OPEN)
  tags        String[]
  requirements String[]
  creatorId   String
  creator     User        @relation("BountyCreator", fields: [creatorId], references: [id])
  assigneeId  String?
  assignee    User?       @relation("BountyAssignee", fields: [assigneeId], references: [id])
  submissions Submission[]
  reviews     Review[]
  deadline    DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("bounties")
}

model Submission {
  id          String   @id @default(cuid())
  bountyId    String
  bounty      Bounty   @relation(fields: [bountyId], references: [id])
  submitterId String
  submitter   User     @relation(fields: [submitterId], references: [id])
  content     String
  attachments String[]
  status      SubmissionStatus @default(PENDING)
  reviews     Review[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("submissions")
}

model Review {
  id           String   @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id])
  reviewerId   String
  reviewer     User     @relation(fields: [reviewerId], references: [id])
  bountyId     String
  bounty       Bounty   @relation(fields: [bountyId], references: [id])
  rating       Int
  comment      String
  approved     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("reviews")
}

model Course {
  id            String   @id @default(cuid())
  title         String
  description   String
  category      String
  difficulty    String
  duration      Int      // in hours
  thumbnail     String?
  creatorId     String
  creator       User     @relation("CourseCreator", fields: [creatorId], references: [id])
  assessments   Assessment[]
  certificates  Certificate[]
  enrollments   Enrollment[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("courses")
}

model Assessment {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id])
  title       String
  type        AssessmentType @default(FINAL)
  passingScore Int     @default(70)
  questions   Json     // Array of questions with options and correct answers
  attempts    AssessmentAttempt[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("assessments")
}

model AssessmentAttempt {
  id            String   @id @default(cuid())
  assessmentId  String
  assessment    Assessment @relation(fields: [assessmentId], references: [id])
  userId        String
  user          User     @relation("AssessmentAttempts", fields: [userId], references: [id])
  score         Int
  passed        Boolean  @default(false)
  answers       Json     // User's answers
  completedAt   DateTime @default(now())

  @@map("assessment_attempts")
}

model Enrollment {
  id         String   @id @default(cuid())
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id])
  userId     String
  user       User     @relation("Enrollments", fields: [userId], references: [id])
  progress   Float    @default(0.0) // 0-100 percentage
  completed  Boolean  @default(false)
  completedAt DateTime?
  enrolledAt DateTime @default(now())

  @@map("enrollments")
}

model Certificate {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation("Certificates", fields: [userId], references: [id])
  courseId          String
  course            Course   @relation(fields: [courseId], references: [id])
  assessmentId      String
  stellarTxHash     String?  @unique // Stellar transaction hash
  certificateHash   String   @unique // SHA-256 hash of certificate data
  stellarDataKey    String?  // Key used in MANAGE_DATA operation
  walletAddress     String   // Learner's Stellar wallet address
  completionDate    DateTime @default(now())
  stellarExplorerUrl String?
  verified          Boolean  @default(false)
  metadata          Json?    // Additional certificate metadata

  @@map("certificates")
}

model Certification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  description String
  issuer      String
  issueDate   DateTime
  expiryDate  DateTime?
  credentialUrl String?
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("certifications")
}

enum BountyCategory {
  CONTENT_CREATION
  DEVELOPMENT
  DESIGN_UX
  TRANSLATION
  REVIEW
  MAINTENANCE
  RESEARCH
  COMMUNITY
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum BountyStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  UNDER_REVIEW
  COMPLETED
  CANCELLED
}

enum AssessmentType {
  QUIZ
  ASSIGNMENT
  FINAL
  PRACTICE
}

enum SubmissionStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  REVISION_REQUIRED
}
